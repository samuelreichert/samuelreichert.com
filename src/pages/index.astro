---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
---

<BaseLayout
  title="Samuel Reichert — Senior Frontend Engineer"
  description="The personal site of Samuel Reichert. Senior Frontend Engineer, React Native developer, builder."
  path="/"
>
  <style>
    .hero {
      position: relative;
      padding: clamp(4rem, 12vh, 9rem) 0 clamp(4rem, 10vh, 7rem);
      text-align: center;
      overflow: hidden;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 50% 40%, rgba(201,168,76,0.18), transparent 60%),
        radial-gradient(ellipse 90% 60% at 50% 100%, rgba(201,168,76,0.08), transparent 70%);
      pointer-events: none;
    }
    html.light-mode .hero::before {
      background:
        radial-gradient(ellipse 60% 50% at 50% 40%, rgba(142,116,48,0.14), transparent 60%),
        radial-gradient(ellipse 90% 60% at 50% 100%, rgba(142,116,48,0.06), transparent 70%);
    }
    .hero-eyebrow {
      margin-bottom: 2rem;
      justify-content: center;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem 1.1rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      background: color-mix(in oklab, var(--color-bg-elev) 65%, transparent);
      backdrop-filter: blur(10px);
      white-space: nowrap;
      max-width: 100%;
    }
    .hero-eyebrow::before { display: none; }
    .hero-eyebrow .label {
      font-size: .68rem;
      letter-spacing: .26em;
      text-transform: uppercase;
      color: var(--color-text-muted);
    }
    .hero-eyebrow .dot {
      width: 6px; height: 6px; border-radius: 999px;
      background: var(--color-gold);
      box-shadow: 0 0 10px var(--color-gold);
      animation: pulse 2.4s var(--ease-in-out) infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: .55; transform: scale(.85); }
    }
    .hero h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      font-weight: 500;
      line-height: 1.0;
      letter-spacing: -0.035em;
      margin: 0 auto;
      max-width: 18ch;
      padding-bottom: 0.12em;
    }
    .hero h1 .italic { font-style: italic; font-weight: 400; }
    .hero h1 .ampersand { font-style: italic; color: var(--color-gold); font-weight: 400; }
    .hero-sub {
      margin: 2.75rem auto 0;
      font-family: var(--font-sans);
      font-size: clamp(0.85rem, 1.3vw, 1.05rem);
      color: var(--color-text-muted);
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 400;
      display: inline-flex;
      gap: 0.9rem;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
    }
    .hero-sub .sep { color: var(--color-gold); opacity: .8; }
    .hero-tag {
      margin: 2rem auto 0;
      max-width: 52ch;
      color: var(--color-text-muted);
      font-size: 1.1rem;
      line-height: 1.55;
    }
    .hero-cta {
      display: inline-flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.85rem;
      margin-top: 2.75rem;
    }
    .hero-marquee {
      margin-top: 4rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.25rem;
      color: var(--color-text-faint);
      font-size: 0.72rem;
      letter-spacing: 0.36em;
      text-transform: uppercase;
    }
    .hero-marquee .star { color: var(--color-gold); }

    /* Preview cards */
    .preview-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .preview-card {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 360px;
      padding: 2rem;
    }
    .preview-card .pc-num {
      font-family: var(--font-display);
      font-style: italic;
      color: var(--color-gold);
      font-size: 1rem;
      letter-spacing: 0.05em;
    }
    .preview-card h3 {
      font-family: var(--font-display);
      font-size: 2.4rem;
      font-weight: 500;
      line-height: 1;
      letter-spacing: -0.02em;
      margin-top: 1.25rem;
    }
    .preview-card h3 .it { font-style: italic; font-weight: 400; }
    .preview-card .pc-desc {
      color: var(--color-text-muted);
      font-size: 0.98rem;
      margin-top: 0.85rem;
      max-width: 28ch;
    }
    .preview-card .pc-go {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      color: var(--color-text);
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 500;
      margin-top: 2rem;
      transition: color .3s var(--ease-out);
    }
    .preview-card:hover .pc-go { color: var(--color-gold); }
    .preview-card .pc-go .arr {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 999px;
      border: 1px solid var(--color-border);
      transition: border-color .3s var(--ease-out), background-color .3s var(--ease-out);
    }
    .preview-card:hover .pc-go .arr {
      border-color: var(--color-gold);
      background: color-mix(in oklab, var(--color-gold) 10%, transparent);
    }
    .preview-card .pc-go .arr svg { transition: transform .35s var(--ease-out); }
    .preview-card:hover .pc-go .arr svg { transform: translateX(3px); }

    /* Snapshot strip */
    .snapshot {
      margin-top: var(--space-7);
      padding: var(--space-5) 2.25rem;
      border-radius: var(--r-xl);
      background: var(--color-card);
      border: 1px solid var(--color-border-soft);
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 2.5rem;
      align-items: center;
      position: relative;
      overflow: hidden;
    }
    .snapshot::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, transparent 60%, color-mix(in oklab, var(--color-gold) 8%, transparent) 100%);
      pointer-events: none;
    }
    .snapshot-label { position: relative; z-index: 1; }
    .snapshot-label .eyebrow { margin-bottom: 0.5rem; }
    .snapshot-label .label-text {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 1.5rem;
      line-height: 1.1;
      color: var(--color-text);
      max-width: 16ch;
    }
    .snapshot-items {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
      position: relative;
      z-index: 1;
    }
    .snap-item {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 0.5rem 0;
      border-left: 1px solid var(--color-rule);
      padding-left: 1.25rem;
    }
    .snap-item .sym { font-size: 1.4rem; line-height: 1; color: var(--color-gold); }
    .snap-item .nm { font-family: var(--font-display); font-size: 1.35rem; font-weight: 500; line-height: 1; }
    .snap-item .ds { color: var(--color-text-muted); font-size: 0.85rem; }

    @media (max-width: 980px) {
      .preview-grid { grid-template-columns: 1fr; }
      .preview-card { min-height: 240px; }
      .snapshot { grid-template-columns: 1fr; gap: 1.5rem; padding: 1.75rem; }
      .snapshot-items { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 520px) {
      .hero-marquee { gap: 1.25rem; font-size: 0.65rem; }
      .hero-sub { font-size: 0.7rem; gap: 0.5rem; }
    }
  </style>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="hero-eyebrow reveal-eager">
        <span class="dot"></span>
        <span class="label">Available for select projects · 2026</span>
      </span>

      <h1 class="reveal-eager">
        Samuel <span class="ampersand">&amp;</span> the<br/>
        <span class="italic">craft</span> of interfaces.
      </h1>

      <div class="hero-sub reveal-eager" aria-label="Senior Frontend Engineer, React Native, Builder">
        <span>Senior</span>
        <span>Frontend</span>
        <span class="sep">·</span>
        <span>React Native</span>
        <span class="sep">·</span>
        <span>Builder</span>
      </div>

      <p class="hero-tag reveal-eager">
        I design and engineer products where every pixel earns its place — modern web,
        mobile, and the quiet details that make software feel inevitable.
      </p>

      <div class="hero-cta reveal-eager">
        <a class="btn btn-primary" href="/projects">
          View Projects
          <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn-ghost" href="/about">
          My Story
          <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="hero-marquee reveal-eager">
        <span>React</span><span class="star">✦</span>
        <span>TypeScript</span><span class="star">✦</span>
        <span>React Native</span><span class="star">✦</span>
        <span>Next.js</span><span class="star">✦</span>
        <span>Astro</span>
      </div>
    </div>
  </section>

  <!-- Preview cards -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">The Site</span>
        <h2>Three doors. <span class="serif" style="font-style:italic;color:var(--color-gold);">One story.</span></h2>
        <p class="muted" style="max-width:54ch;">A portfolio is a conversation. Pick where you'd like to start.</p>
      </div>

      <div class="preview-grid">
        <a href="/about" class="lux-card preview-card reveal" style="--reveal-delay:80ms;">
          <div>
            <div class="pc-num">— 01</div>
            <h3>About <span class="it">me</span></h3>
          </div>
          <div>
            <p class="pc-desc">Who I am beyond the code — the books, the kilometres, the long-term thesis.</p>
            <span class="pc-go">
              Read more
              <span class="arr">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </span>
          </div>
        </a>

        <a href="/experience" class="lux-card preview-card reveal" style="--reveal-delay:160ms;">
          <div>
            <div class="pc-num">— 02</div>
            <h3>10+ years <span class="it">building</span> interfaces</h3>
          </div>
          <div>
            <p class="pc-desc">A chronological route through the products, teams and craft I've shaped.</p>
            <span class="pc-go">
              See timeline
              <span class="arr">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </span>
          </div>
        </a>

        <a href="/projects" class="lux-card preview-card reveal" style="--reveal-delay:240ms;">
          <div>
            <div class="pc-num">— 03</div>
            <h3>What I've <span class="it">shipped</span></h3>
          </div>
          <div>
            <p class="pc-desc">Open source, side bets, and the mobile work taking shape behind the curtain.</p>
            <span class="pc-go">
              Browse projects
              <span class="arr">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Personal snapshot -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="snapshot reveal">
        <div class="snapshot-label">
          <span class="eyebrow">Off the keyboard</span>
          <div class="label-text">A life shaped by curiosity.</div>
        </div>
        <div class="snapshot-items">
          <div class="snap-item">
            <span class="sym">✈</span>
            <span class="nm">Travel</span>
            <span class="ds">New cities, slowly.</span>
          </div>
          <div class="snap-item">
            <span class="sym">◈</span>
            <span class="nm">Investing</span>
            <span class="ds">Long-term horizon.</span>
          </div>
          <div class="snap-item">
            <span class="sym">❦</span>
            <span class="nm">Reading</span>
            <span class="ds">Fantasy to finance.</span>
          </div>
          <div class="snap-item">
            <span class="sym">⟁</span>
            <span class="nm">Fitness</span>
            <span class="ds">Daily reset.</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
