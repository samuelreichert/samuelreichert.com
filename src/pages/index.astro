---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
---

<BaseLayout path="/">
  <section>
    <h1>{siteConfig.name}</h1>
    <p>
      Frontend engineer focused on React, with experience in React Native and
      Node.js. 8+ years of experience, working with JavaScript since 2014.
    </p>
    <p>
      <a href="/projects">See projects</a> ·
      <a href="/experience">See experience</a> ·
      <a href={`mailto:${siteConfig.email}`}>Get in touch</a>
    </p>
  </section>
</BaseLayout>
