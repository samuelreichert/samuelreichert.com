---
import "../styles/home.css";
import Icon from "../components/icons/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Samuel Reichert — Senior Frontend Engineer"
  description="The personal site of Samuel Reichert. Senior Frontend Engineer, React Native developer, builder."
  path="/"
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="hero-eyebrow reveal-eager">
        <span class="dot"></span>
        <span class="label">Focused on current work</span>
      </span>

      <h1 class="reveal-eager">
        Samuel <span class="ampersand">&amp;</span> the<br />
        <span class="italic">craft</span> of interfaces.
      </h1>

      <div
        class="hero-sub reveal-eager"
        aria-label="Senior Frontend Engineer, React Native, Builder"
      >
        <span>Senior</span>
        <span>Frontend</span>
        <span class="sep">·</span>
        <span>React Native</span>
        <span class="sep">·</span>
        <span>Builder</span>
      </div>

      <p class="hero-tag reveal-eager">
        I design and engineer products where every pixel earns its place —
        modern web, mobile, and the quiet details that make software feel
        inevitable.
      </p>

      <div class="hero-cta reveal-eager">
        <a class="btn btn-primary" href="/projects">
          View Projects
          <Icon name="arrow-right" class="arrow" size={14} />
        </a>
        <a class="btn btn-ghost" href="/about">
          My Story
          <Icon name="arrow-right" class="arrow" size={14} />
        </a>
      </div>

      <div class="hero-marquee reveal-eager">
        <span>React</span><span class="star">✦</span>
        <span>TypeScript</span><span class="star">✦</span>
        <span>React Native</span><span class="star">✦</span>
        <span>Next.js</span><span class="star">✦</span>
        <span>Astro</span>
      </div>
    </div>
  </section>

  <!-- Preview cards -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">The Site</span>
        <h2>
          Three doors. <span
            class="serif"
            style="font-style:italic;color:var(--color-gold);">One story.</span>
        </h2>
        <p class="muted" style="max-width:54ch;">
          A portfolio is a conversation. Pick where you'd like to start.
        </p>
      </div>

      <div class="preview-grid">
        <a
          href="/about"
          class="lux-card preview-card reveal"
          style="--reveal-delay:80ms;"
        >
          <div>
            <div class="pc-num">— 01</div>
            <h3>About <span class="it">me</span></h3>
          </div>
          <div>
            <p class="pc-desc">
              Who I am beyond the code — the books, the kilometres, the
              long-term thesis.
            </p>
            <span class="pc-go">
              Read more
              <span class="arr">
                <Icon name="arrow-right" size={12} />
              </span>
            </span>
          </div>
        </a>

        <a
          href="/experience"
          class="lux-card preview-card reveal"
          style="--reveal-delay:160ms;"
        >
          <div>
            <div class="pc-num">— 02</div>
            <h3>10+ years <span class="it">building</span> interfaces</h3>
          </div>
          <div>
            <p class="pc-desc">
              A chronological route through the products, teams and craft I've
              shaped.
            </p>
            <span class="pc-go">
              See timeline
              <span class="arr">
                <Icon name="arrow-right" size={12} />
              </span>
            </span>
          </div>
        </a>

        <a
          href="/projects"
          class="lux-card preview-card reveal"
          style="--reveal-delay:240ms;"
        >
          <div>
            <div class="pc-num">— 03</div>
            <h3>What I've <span class="it">shipped</span></h3>
          </div>
          <div>
            <p class="pc-desc">
              Open source, side bets, and the mobile work taking shape behind
              the curtain.
            </p>
            <span class="pc-go">
              Browse projects
              <span class="arr">
                <Icon name="arrow-right" size={12} />
              </span>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Personal snapshot -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="snapshot reveal">
        <div class="snapshot-label">
          <span class="eyebrow">Off the keyboard</span>
          <div class="label-text">A life shaped by curiosity.</div>
        </div>
        <div class="snapshot-items">
          <div class="snap-item">
            <span class="sym">✈</span>
            <span class="nm">Travel</span>
            <span class="ds">New cities, slowly.</span>
          </div>
          <div class="snap-item">
            <span class="sym">◈</span>
            <span class="nm">Investing</span>
            <span class="ds">Long-term horizon.</span>
          </div>
          <div class="snap-item">
            <span class="sym">❦</span>
            <span class="nm">Reading</span>
            <span class="ds">Fantasy to finance.</span>
          </div>
          <div class="snap-item">
            <span class="sym">⟁</span>
            <span class="nm">Fitness</span>
            <span class="ds">Weekly reset.</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
