---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const entries = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);

const allTags = [...new Set(entries.flatMap((e) => e.data.tags))];
---

<BaseLayout
  title="Projects — Samuel Reichert"
  description="Open source repositories, side bets, and React Native work in progress."
  path="/projects"
>
  <style>
    .proj-hero { padding: clamp(3rem, 8vh, 6rem) 0 clamp(2rem, 4vh, 3rem); }
    .proj-hero h1 { font-size: var(--fs-display); line-height: 1; max-width: 14ch; }
    .proj-hero h1 .it { font-style: italic; color: var(--color-gold); font-weight: 400; }
    .proj-hero p.lede { margin-top: 1.5rem; color: var(--color-text-muted); font-size: 1.125rem; max-width: 56ch; }

    .filters {
      margin-top: 2.5rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.6rem;
      padding: 1rem 1.25rem;
      border: 1px solid var(--color-border-soft);
      border-radius: 999px;
      background: color-mix(in oklab, var(--color-bg-elev) 60%, transparent);
      backdrop-filter: blur(10px);
    }
    .filters .label { font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--color-text-muted); margin-right: 0.5rem; }
    .pill {
      border: 1px solid var(--color-border-soft);
      background: transparent;
      color: var(--color-text-muted);
      padding: 0.5rem 1rem;
      font-family: var(--font-sans);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      border-radius: 999px;
      cursor: pointer;
      transition: all .25s var(--ease-out);
    }
    .pill:hover { color: var(--color-text); border-color: var(--color-border); }
    .pill.active { background: var(--gold-gradient); color: #0A0A0A; border-color: transparent; font-weight: 600; }

    .repo-grid {
      margin-top: 2rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    /* Repo card styles — shared with ProjectCard component */
    :global(.repo-card) {
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      min-height: 240px;
    }
    :global(.repo-card .top) { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    :global(.repo-card .name) {
      font-family: var(--font-display);
      font-size: 1.45rem;
      font-weight: 500;
      line-height: 1.1;
      letter-spacing: -0.01em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    :global(.repo-card .name svg) { color: var(--color-gold); }
    :global(.repo-card .desc) { color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.55; flex: 1; }
    :global(.repo-card .meta) {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      padding-top: 1rem;
      border-top: 1px solid var(--color-rule);
      font-size: 0.82rem;
      color: var(--color-text-muted);
      flex-wrap: wrap;
    }
    :global(.repo-card .meta .lang) { display: inline-flex; align-items: center; gap: 0.4rem; }
    :global(.repo-card .meta .lang-dot) { width: 9px; height: 9px; border-radius: 999px; display: inline-block; }
    :global(.repo-card .arrow-out) {
      width: 36px; height: 36px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      border: 1px solid var(--color-border);
      color: var(--color-text-muted);
      transition: all .3s var(--ease-out);
      flex-shrink: 0;
    }
    :global(.repo-card:hover .arrow-out) {
      border-color: var(--color-gold);
      color: var(--color-gold);
      background: color-mix(in oklab, var(--color-gold) 10%, transparent);
    }
    :global(.repo-card .card-links) {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    /* React Native section */
    .rn-section { margin-top: var(--space-7); }
    .rn-frame {
      margin-top: 2rem;
      padding: 4rem 2rem;
      border-radius: var(--r-xl);
      background: var(--color-card);
      border: 1px solid var(--color-border);
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 4rem;
      align-items: center;
      position: relative;
      overflow: hidden;
    }
    .rn-frame::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 20% 50%, rgba(201,168,76,0.15), transparent 55%);
      pointer-events: none;
    }
    html.light-mode .rn-frame::before {
      background: radial-gradient(ellipse at 20% 50%, rgba(142,116,48,0.10), transparent 55%);
    }

    .phone {
      position: relative;
      width: 230px; height: 470px;
      border-radius: 38px;
      background: linear-gradient(180deg, #1a1a1a 0%, #0a0a0a 100%);
      padding: 10px;
      box-shadow: 0 0 0 1px var(--color-gold), 0 30px 60px rgba(0,0,0,0.6), 0 0 60px rgba(201,168,76,0.18), inset 0 1px 0 rgba(255,255,255,0.08);
      z-index: 1;
    }
    html.light-mode .phone {
      background: linear-gradient(180deg, #2a2620 0%, #1a1610 100%);
      box-shadow: 0 0 0 1px var(--color-gold), 0 30px 60px rgba(20,16,8,0.25), 0 0 60px rgba(142,116,48,0.18);
    }
    .phone::before {
      content: "";
      position: absolute;
      top: 22px; left: 50%;
      transform: translateX(-50%);
      width: 90px; height: 22px;
      background: #000;
      border-radius: 999px;
      z-index: 2;
    }
    .phone-screen {
      position: absolute;
      inset: 10px;
      border-radius: 30px;
      background: var(--color-bg);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 24px 40px;
      text-align: center;
    }
    .phone-screen::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 40%, rgba(201,168,76,0.18), transparent 65%);
    }
    .phone-screen .ps-monogram {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 4rem;
      line-height: 1;
      background: var(--gold-gradient);
      -webkit-background-clip: text;
              background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
      position: relative;
    }
    .phone-screen .ps-line { margin-top: 1.5rem; width: 48px; height: 1px; background: var(--color-gold); position: relative; }
    .phone-screen .ps-label { margin-top: 1rem; font-size: 0.65rem; letter-spacing: 0.32em; text-transform: uppercase; color: var(--color-text-muted); position: relative; }
    .phone-screen .ps-title { margin-top: 0.5rem; font-family: var(--font-display); font-size: 1.3rem; font-style: italic; color: var(--color-text); line-height: 1.2; position: relative; }

    .rn-text { position: relative; z-index: 1; }
    .rn-text h2 { font-size: clamp(2rem, 4vw, 3.25rem); line-height: 1; }
    .rn-text h2 .it { font-style: italic; color: var(--color-gold); font-weight: 400; }
    .rn-text p { margin-top: 1.25rem; color: var(--color-text-muted); font-size: 1.05rem; line-height: 1.65; max-width: 48ch; }
    .rn-text .tease {
      margin-top: 2rem;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.55rem 1.1rem;
      border: 1px solid var(--color-gold);
      border-radius: 999px;
      color: var(--color-gold);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .rn-text .tease .pulse {
      width: 6px; height: 6px;
      border-radius: 999px;
      background: var(--color-gold);
      animation: pulse 2s var(--ease-in-out) infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: .4; transform: scale(.7); }
    }

    @media (max-width: 980px) {
      .repo-grid { grid-template-columns: 1fr 1fr; }
      .rn-frame { grid-template-columns: 1fr; gap: 2.5rem; padding: 3rem 1.5rem; justify-items: center; text-align: center; }
      .rn-text p, .rn-text h2 { margin-left: auto; margin-right: auto; }
    }
    @media (max-width: 640px) {
      .repo-grid { grid-template-columns: 1fr; }
    }
  </style>

  <section class="proj-hero">
    <div class="container">
      <span class="eyebrow reveal-eager">Projects</span>
      <h1 class="reveal-eager" style="margin-top:1rem;">
        What I've <span class="it">shipped.</span>
      </h1>
      <p class="lede reveal-eager">
        Open source experiments, freelance work and side bets. Repositories pulled from
        my content collection — what you see is what's currently listed.
      </p>

      <div class="filters reveal" role="tablist" aria-label="Filter by language">
        <span class="label">Filter</span>
        <button class="pill active" data-filter="all" type="button">All</button>
        {allTags.map((tag) => (
          <button class="pill" data-filter={tag} type="button">{tag}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="repo-grid" id="repo-grid">
        {entries.map((entry, i) => <ProjectCard entry={entry} index={i} />)}
      </div>

      <section class="rn-section">
        <div class="section-head reveal">
          <span class="eyebrow">React Native</span>
          <h2>Mobile work, <span class="serif" style="font-style:italic;color:var(--color-gold);">behind the curtain.</span></h2>
        </div>

        <div class="rn-frame reveal">
          <div class="phone" aria-hidden="true">
            <div class="phone-screen">
              <div class="ps-monogram">SR</div>
              <div class="ps-line"></div>
              <div class="ps-label">Coming Soon</div>
              <div class="ps-title">A new mobile<br/>experience</div>
            </div>
          </div>

          <div class="rn-text">
            <h2>Mobile projects<br/><span class="it">coming soon.</span></h2>
            <p>
              A handful of React Native apps are in flight — a portfolio tracker, a
              travel journal, and one or two ideas I'm not ready to spoil. They'll land
              here once they're worth your tap.
            </p>
            <p>
              In the meantime, watch the GitHub above for previews and components.
            </p>
            <span class="tease">
              <span class="pulse"></span>
              In the workshop · 2026
            </span>
          </div>
        </div>
      </section>
    </div>
  </section>

  <script>
    (function () {
      const pills = document.querySelectorAll<HTMLButtonElement>(".filters .pill");
      const cards = document.querySelectorAll<HTMLElement>(".repo-card");
      pills.forEach((p) => {
        p.addEventListener("click", () => {
          pills.forEach((x) => x.classList.remove("active"));
          p.classList.add("active");
          const filter = p.getAttribute("data-filter");
          cards.forEach((c) => {
            const lang = c.getAttribute("data-lang");
            c.style.display = (filter === "all" || lang === filter) ? "" : "none";
          });
        });
      });
    })();
  </script>
</BaseLayout>
