---
import Icon from "../components/icons/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
import "../styles/contact.css";
---

<BaseLayout
  title="Contact | Samuel Reichert"
  description="Let's build something great together."
  path="/contact"
>
  <section class="page-hero page-hero--center ct-hero">
    <div class="container">
      <span class="eyebrow eyebrow-center reveal-eager">Contact</span>
      <h1 class="reveal-eager">
        Let's build something<br />
        <span class="it">great together.</span>
      </h1>
      <p class="lede reveal-eager">
        I read every message. Whether it's a product to ship, an idea to
        interrogate, or simply hello — pick a door below and walk through.
      </p>
    </div>
  </section>

  <section class="section section-flush">
    <div class="container">
      <div class="links">
        <a
          class="lux-card link-card reveal reveal-delay-60"
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener"
        >
          <div class="top">
            <div class="ic">
              <Icon name="linkedin" size={22} />
            </div>
            <span class="arrow-out"
              ><Icon name="external-link" size={14} /></span
            >
          </div>
          <div>
            <span class="label">Connect</span>
            <div class="name">LinkedIn</div>
            <div class="handle">/in/samuelreichert</div>
          </div>
        </a>

        <a
          class="lux-card link-card reveal reveal-delay-140"
          href={siteConfig.github}
          target="_blank"
          rel="noopener"
        >
          <div class="top">
            <div class="ic">
              <Icon name="github" size={22} />
            </div>
            <span class="arrow-out"
              ><Icon name="external-link" size={14} /></span
            >
          </div>
          <div>
            <span class="label">Open Source</span>
            <div class="name">GitHub</div>
            <div class="handle">@samuelreichert</div>
          </div>
        </a>

        <a
          class="lux-card link-card reveal reveal-delay-220"
          href={`mailto:${siteConfig.email}`}
        >
          <div class="top">
            <div class="ic">
              <Icon name="mail" size={22} />
            </div>
            <span class="arrow-out"
              ><Icon name="external-link" size={14} /></span
            >
          </div>
          <div>
            <span class="label">Direct</span>
            <div class="name">
              <span class="it">Email</span>
            </div>
            <div class="handle">
              {siteConfig.email}
            </div>
          </div>
        </a>

        <a
          class="lux-card link-card reveal reveal-delay-300"
          href={siteConfig.resumeUrl}
          target="_blank"
          rel="noopener"
        >
          <div class="top">
            <div class="ic">
              <Icon name="file" size={22} />
            </div>
            <span class="arrow-out"
              ><Icon name="external-link" size={14} /></span
            >
          </div>
          <div>
            <span class="label">Download</span>
            <div class="name">
              <span class="it">CV</span>
            </div>
            <div class="handle">PDF · Google Docs</div>
          </div>
        </a>
      </div>

      <div class="location reveal">
        <div class="loc-block">
          <div class="loc-ic">
            <Icon name="pin" size={20} />
          </div>
          <div class="loc-text">
            <div class="label">Based in</div>
            <div class="value">Rotterdam, NL</div>
          </div>
        </div>

        <div class="loc-block">
          <div class="loc-ic">
            <Icon name="clock" size={20} />
          </div>
          <div class="loc-text">
            <div class="label">Working on</div>
            <div class="value">CET · Central European Time</div>
          </div>
        </div>

        <div class="clock">
          <span class="dot"></span>
          <span id="local-time">--:--</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
