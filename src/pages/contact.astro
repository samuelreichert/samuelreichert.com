---
import Icon from "../components/icons/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
import "../styles/contact.css";
---

<BaseLayout
  title="Contact | Samuel Reichert"
  description="Let's build something great together."
  path="/contact"
>
  <section class="ct-hero">
    <div class="container">
      <span class="eyebrow reveal-eager" style="justify-content:center;"
        >Contact</span
      >
      <h1 class="reveal-eager">
        Let's build something<br />
        <span class="it">great together.</span>
      </h1>
      <p class="lede reveal-eager">
        I read every message. Whether it's a product to ship, an idea to
        interrogate, or simply hello — pick a door below and walk through.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="links">
        <a
          class="lux-card link-card reveal"
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener"
          style="--reveal-delay:60ms;"
        >
          <div class="top">
            <div class="ic">
              <Icon name="linkedin" size={22} />
            </div>
            <span class="arrow-out"><Icon name="external-link" size={14} /></span>
          </div>
          <div>
            <span class="label">Connect</span>
            <div class="name" style="margin-top:0.5rem;">LinkedIn</div>
            <div class="handle" style="margin-top:0.5rem;">
              /in/samuelreichert
            </div>
          </div>
        </a>

        <a
          class="lux-card link-card reveal"
          href={siteConfig.github}
          target="_blank"
          rel="noopener"
          style="--reveal-delay:140ms;"
        >
          <div class="top">
            <div class="ic">
              <Icon name="github" size={22} />
            </div>
            <span class="arrow-out"><Icon name="external-link" size={14} /></span>
          </div>
          <div>
            <span class="label">Open Source</span>
            <div class="name" style="margin-top:0.5rem;">GitHub</div>
            <div class="handle" style="margin-top:0.5rem;">@samuelreichert</div>
          </div>
        </a>

        <a
          class="lux-card link-card reveal"
          href={`mailto:${siteConfig.email}`}
          style="--reveal-delay:220ms;"
        >
          <div class="top">
            <div class="ic">
              <Icon name="mail" size={22} />
            </div>
            <span class="arrow-out"><Icon name="external-link" size={14} /></span>
          </div>
          <div>
            <span class="label">Direct</span>
            <div class="name" style="margin-top:0.5rem;">
              <span class="it">Email</span>
            </div>
            <div class="handle" style="margin-top:0.5rem;">
              {siteConfig.email}
            </div>
          </div>
        </a>

        <a
          class="lux-card link-card reveal"
          href={siteConfig.resumeUrl}
          target="_blank"
          rel="noopener"
          style="--reveal-delay:300ms;"
        >
          <div class="top">
            <div class="ic">
              <Icon name="file" size={22} />
            </div>
            <span class="arrow-out"><Icon name="external-link" size={14} /></span>
          </div>
          <div>
            <span class="label">Download</span>
            <div class="name" style="margin-top:0.5rem;">
              <span class="it">Résumé</span>
            </div>
            <div class="handle" style="margin-top:0.5rem;">
              PDF · Google Docs
            </div>
          </div>
        </a>
      </div>

      <div class="location reveal">
        <div class="loc-block">
          <div class="loc-ic">
            <Icon name="pin" size={20} />
          </div>
          <div class="loc-text">
            <div class="label">Based in</div>
            <div class="value">Rotterdam, NL</div>
          </div>
        </div>

        <div class="loc-block">
          <div class="loc-ic">
            <Icon name="clock" size={20} />
          </div>
          <div class="loc-text">
            <div class="label">Working on</div>
            <div class="value">CET · Central European Time</div>
          </div>
        </div>

        <div class="clock">
          <span class="dot"></span>
          <span id="local-time">--:--</span>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
