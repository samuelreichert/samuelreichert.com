---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Samuel Reichert"
  description="Page not found."
  path="/404"
>
  <style>
    .not-found {
      padding: clamp(6rem, 16vh, 12rem) 0 clamp(4rem, 10vh, 8rem);
      text-align: center;
    }
    .not-found .code {
      font-family: var(--font-display);
      font-size: clamp(6rem, 20vw, 12rem);
      font-weight: 500;
      line-height: 1;
      letter-spacing: -0.05em;
      background: var(--gold-gradient);
      -webkit-background-clip: text;
              background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    .not-found h1 {
      margin-top: 1.5rem;
      font-size: var(--fs-h2);
      color: var(--color-text);
    }
    .not-found p {
      margin: 1.25rem auto 0;
      color: var(--color-text-muted);
      font-size: 1.1rem;
      max-width: 40ch;
    }
    .not-found .back {
      margin-top: 2.5rem;
      display: inline-flex;
    }
  </style>

  <section class="not-found">
    <div class="container">
      <div class="code reveal-eager">404</div>
      <h1 class="reveal-eager">Page not found.</h1>
      <p class="reveal-eager">That page doesn't exist or was moved.</p>
      <div class="back reveal-eager">
        <a class="btn btn-ghost" href="/">← Back home</a>
      </div>
    </div>
  </section>
</BaseLayout>
