---
import "../styles/not-found.css";
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Samuel Reichert"
  description="Page not found."
  path="/404"
>

  <section class="not-found">
    <div class="container">
      <div class="code reveal-eager">404</div>
      <h1 class="reveal-eager">Page not found.</h1>
      <p class="reveal-eager">That page doesn't exist or was moved.</p>
      <div class="back reveal-eager">
        <a class="btn btn-ghost" href="/">← Back home</a>
      </div>
    </div>
  </section>
</BaseLayout>
