---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceCard from '../components/ExperienceCard.astro';

const entries = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Experience — Samuel Reichert"
  description="10+ years of building interfaces. The companies, roles, and tools."
  path="/experience"
>
  <style>
    .exp-hero { padding: clamp(3rem, 8vh, 6rem) 0 clamp(2rem, 4vh, 3rem); }
    .exp-hero h1 { font-size: var(--fs-display); line-height: 1; max-width: 14ch; }
    .exp-hero h1 .it { font-style: italic; color: var(--color-gold); font-weight: 400; }
    .exp-hero p.lede { margin-top: 1.5rem; color: var(--color-text-muted); font-size: 1.125rem; max-width: 56ch; }

    .timeline {
      position: relative;
      margin-top: 2rem;
    }
    .timeline::before {
      content: "";
      position: absolute;
      left: 18px; top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(180deg, transparent, var(--color-border) 8%, var(--color-border) 92%, transparent);
    }

    /* Timeline item styles — shared with ExperienceCard component */
    :global(.tl-item) {
      position: relative;
      padding: 0 0 3rem 60px;
    }
    :global(.tl-item:last-child) { padding-bottom: 0; }
    :global(.tl-dot) {
      position: absolute;
      left: 11px; top: 6px;
      width: 16px; height: 16px;
      border-radius: 999px;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      box-shadow: 0 0 0 4px var(--color-bg);
    }
    :global(.tl-item.is-current .tl-dot) {
      background: var(--gold-gradient);
      border-color: var(--color-gold);
      box-shadow: 0 0 0 4px var(--color-bg), 0 0 16px rgba(201,168,76,0.5);
    }
    :global(.tl-card) {
      padding: 1.75rem 2rem;
      display: grid;
      grid-template-columns: 64px 1fr auto;
      gap: 1.5rem;
      align-items: start;
    }
    :global(.tl-logo) {
      width: 56px; height: 56px;
      border-radius: var(--r-md);
      border: 1px solid var(--color-border);
      background: var(--color-bg-elev);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-style: italic;
      font-size: 1.4rem;
      color: var(--color-gold);
    }
    :global(.tl-body h3) {
      font-family: var(--font-display);
      font-size: 1.6rem;
      font-weight: 500;
      line-height: 1.1;
      letter-spacing: -0.01em;
    }
    :global(.tl-body h3 .role) {
      color: var(--color-text-muted);
      font-style: italic;
      font-weight: 400;
      font-size: 1.1rem;
      display: block;
      margin-top: 0.25rem;
      letter-spacing: 0;
    }
    :global(.tl-body h3 .role a) { color: inherit; text-decoration: none; }
    :global(.tl-body h3 .role a:hover) { color: var(--color-gold); }
    :global(.tl-body p) { margin-top: 0.85rem; color: var(--color-text-muted); font-size: 0.98rem; line-height: 1.65; max-width: 60ch; }
    :global(.tl-body .stack) { margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
    :global(.tl-body .stack span) {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-text-muted);
      padding: 0.35rem 0.75rem;
      border: 1px solid var(--color-border-soft);
      border-radius: 999px;
    }
    :global(.tl-period) {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.95rem;
      color: var(--color-text-muted);
      text-align: right;
      white-space: nowrap;
    }
    :global(.tl-period .badge) {
      display: inline-block;
      margin-top: 0.5rem;
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      background: var(--gold-gradient);
      color: #0A0A0A;
      font-family: var(--font-sans);
      font-style: normal;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    /* Skills section */
    .skills { margin-top: var(--space-7); }
    .skills-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 2rem; }
    .skill-card { padding: 2rem 1.75rem; }
    .skill-card h3 {
      font-family: var(--font-display);
      font-size: 1.55rem;
      font-weight: 500;
      line-height: 1;
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
    }
    .skill-card h3 .num { font-style: italic; color: var(--color-gold); font-size: 0.9rem; }
    .skill-card .tags { margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tag {
      display: inline-flex;
      align-items: center;
      padding: 0.45rem 0.85rem;
      border-radius: 999px;
      border: 1px solid var(--color-border-soft);
      font-size: 0.78rem;
      letter-spacing: 0.04em;
      color: var(--color-text);
      background: color-mix(in oklab, var(--color-bg-elev) 50%, transparent);
      transition: border-color .25s var(--ease-out), color .25s var(--ease-out);
    }
    .tag:hover { border-color: var(--color-gold); color: var(--color-gold); }
    .tag.primary {
      border-color: var(--color-gold);
      color: var(--color-gold);
      background: color-mix(in oklab, var(--color-gold) 8%, transparent);
    }

    @media (max-width: 820px) {
      :global(.tl-card) { grid-template-columns: 56px 1fr; }
      :global(.tl-period) { grid-column: 1 / -1; text-align: left; padding-left: 72px; margin-top: -.25rem; }
      .skills-grid { grid-template-columns: 1fr; }
    }
  </style>

  <section class="exp-hero">
    <div class="container">
      <span class="eyebrow reveal-eager">Experience</span>
      <h1 class="reveal-eager" style="margin-top:1rem;">
        10+ years <span class="it">building</span> interfaces.
      </h1>
      <p class="lede reveal-eager">
        A chronological route through the products, teams and craft I've shaped — from
        first commits to leading frontend on production-grade React and React Native apps.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="timeline">
        {entries.map((entry, i) => <ExperienceCard entry={entry} index={i} />)}
      </div>

      <div class="skills">
        <div class="section-head reveal">
          <span class="eyebrow">Stack &amp; tools</span>
          <h2>The instruments <span class="serif" style="font-style:italic;color:var(--color-gold);">I reach for.</span></h2>
          <p class="muted" style="max-width:54ch;">Gold-tinted tags are the tools I'm closest to — the ones that pay rent every week.</p>
        </div>

        <div class="skills-grid">
          <div class="lux-card skill-card reveal" style="--reveal-delay:60ms;">
            <h3><span class="num">— 01</span> Frontend</h3>
            <div class="tags">
              <span class="tag primary">React</span>
              <span class="tag primary">TypeScript</span>
              <span class="tag primary">Next.js</span>
              <span class="tag">Astro</span>
              <span class="tag">CSS / Tailwind</span>
              <span class="tag">Vite</span>
              <span class="tag">Framer Motion</span>
              <span class="tag">Storybook</span>
            </div>
          </div>

          <div class="lux-card skill-card reveal" style="--reveal-delay:140ms;">
            <h3><span class="num">— 02</span> Mobile</h3>
            <div class="tags">
              <span class="tag primary">React Native</span>
              <span class="tag">Expo</span>
              <span class="tag">Reanimated</span>
              <span class="tag">EAS Build</span>
              <span class="tag">Native Modules</span>
              <span class="tag">App Store / Play</span>
            </div>
          </div>

          <div class="lux-card skill-card reveal" style="--reveal-delay:220ms;">
            <h3><span class="num">— 03</span> Tools &amp; Practice</h3>
            <div class="tags">
              <span class="tag">Figma</span>
              <span class="tag">Design Systems</span>
              <span class="tag">Git / GitHub</span>
              <span class="tag">Vitest / Playwright</span>
              <span class="tag">Node</span>
              <span class="tag">CI / CD</span>
              <span class="tag">A11y</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
