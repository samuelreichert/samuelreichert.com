---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'experience'>;
  index: number;
}

const { entry, index } = Astro.props;
const { company, companyUrl, title, startDate, endDate, description, bullets, skills } = entry.data;
const isCurrent = endDate === 'Present';

const startYear = startDate.split('-')[0];
const endLabel = isCurrent ? 'Now' : endDate.split('-')[0];
const period = `${startYear} — ${endLabel}`;
const logo = company.charAt(0).toUpperCase();
const delay = index * 80;
const delayClass = `reveal-delay-${delay}`;
---

<div class:list={['tl-item reveal', delayClass, { 'is-current': isCurrent }]}>
  <span class="tl-dot"></span>
  <div class="lux-card tl-card">
    <div class="tl-logo">{logo}</div>
    <div class="tl-body">
      <h3>
        <span class="title-line">
          {title}
          {isCurrent && <span class="current-badge">Present</span>}
        </span>
        <span class="role">
          {companyUrl
            ? <a href={companyUrl} rel="noopener" target="_blank">{company}</a>
            : company}
        </span>
      </h3>
      <p>{description}</p>
      {bullets.length > 0 && (
        <details class="tl-more">
          <summary>
            <span>Highlights</span>
            <span class="count">{bullets.length}</span>
          </summary>
          <ul>
            {bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </details>
      )}
      {skills.length > 0 && (
        <div class="stack">
          {skills.map((s) => <span class="tag">{s}</span>)}
        </div>
      )}
    </div>
    <div class="tl-period">
      {period}
    </div>
  </div>
</div>
